#pragma once

#include "base.h"
#include <cstdint>
#include <string_view>

namespace stc::meta {

// clang-format off
inline constexpr std::string_view version        = "@STC_VERSION@";
inline constexpr uint8_t          version_major  =  @PROJECT_VERSION_MAJOR@;
inline constexpr uint8_t          version_minor  =  @PROJECT_VERSION_MINOR@;
inline constexpr uint8_t          version_patch  =  @PROJECT_VERSION_PATCH@;
inline constexpr std::string_view version_suffix = "@STC_VERSION_SUFFIX@";

inline constexpr std::string_view build_commit   = "@STC_GIT_HASH@";
inline constexpr std::string_view build_date     = "@STC_BUILD_DATE@";
inline constexpr std::string_view build_type     = "@CMAKE_BUILD_TYPE@";

inline constexpr std::string_view compiler_id    = "@CMAKE_CXX_COMPILER_ID@";
inline constexpr std::string_view compiler_ver   = "@CMAKE_CXX_COMPILER_VERSION@";
inline constexpr std::string_view system_name    = "@CMAKE_SYSTEM_NAME@";
inline constexpr std::string_view system_arch    = "@CMAKE_SYSTEM_PROCESSOR@";
inline constexpr std::string_view julia_ver      = "@STC_JULIA_VERSION@";
// clang-format on

} // namespace stc::meta
